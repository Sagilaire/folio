---
import BaseLayout from "@/components/templates/BaseLayout.astro";
import { getPublishedBySlug } from "@/lib/posts/repo";
import { readingTime, renderMarkdown, makeExcerpt } from "@/lib/markdown/pipeline";

const { slug } = Astro.params;
const supabase = Astro.locals.supabase;

if (!supabase || !slug) {
  return Astro.redirect("/posts", 302);
}

const post = await getPublishedBySlug(supabase, slug);
if (!post) {
  return new Response("Not found", { status: 404 });
}

const html = await renderMarkdown(post.content);
const minutes = readingTime(post.content);
const excerpt = post.excerpt ?? makeExcerpt(post.content, 200);
const longDate = post.published_at
  ? new Date(post.published_at).toLocaleDateString("en-US", {
      year: "numeric", month: "long", day: "numeric",
    })
  : "";
---
<BaseLayout
  title={post.title}
  description={excerpt}
>
  <article class="container container-reading fade-in" style="padding: var(--sp-7) 0 var(--sp-9);">
    <header class="stack gap-3" style="margin-bottom: var(--sp-7); padding-bottom: var(--sp-5); border-bottom: 1px solid var(--border);">
      <span class="eyebrow">Article</span>
      <h1 class="display display-xl serif" style="margin:0; line-height: 1.05;">
        {post.title}
      </h1>
      <p class="serif muted" style="font-size: var(--fs-20); line-height: 1.45; margin: var(--sp-2) 0;">
        {excerpt}
      </p>
      <div class="row gap-4 muted" style="font-size: var(--fs-14); margin-top: var(--sp-3);">
        <span class="row gap-2">
          <span class="avatar">{post.author.display_name?.[0]?.toUpperCase() ?? "J"}</span>
          {post.author.display_name}
        </span>
        <span>·</span>
        <span>{longDate}</span>
        <span>·</span>
        <span>{minutes} min read</span>
      </div>
    </header>
    <div class="mdx-body fade-in" set:html={html}></div>
  </article>
</BaseLayout>
