---
import type { PostWithAuthor } from "@/lib/types";
import { readingTime, makeExcerpt } from "@/lib/markdown/pipeline";
import { fmtDate } from "@/lib/utils/date";

interface Props {
  post: PostWithAuthor;
}
const { post } = Astro.props;
const minutes = readingTime(post.content);
const excerpt = post.excerpt || makeExcerpt(post.content, 140);
---
<a
  href={`/posts/${post.slug}`}
  class="card card--hover stack gap-2"
  style="text-decoration:none; color:inherit;"
>
  <div class="row gap-2">
    <span class="pill pill--published">Published</span>
    {post.published_at && (
      <span class="muted" style="font-size: var(--fs-12);">{fmtDate(post.published_at)}</span>
    )}
  </div>
  <h2 class="serif display-md" style="margin: var(--sp-2) 0; line-height: 1.15;">
    {post.title}
  </h2>
  <p class="serif muted" style="margin:0; font-size: var(--fs-16); line-height:1.55;">
    {excerpt}
  </p>
  <div
    class="row between"
    style="margin-top: var(--sp-3); padding-top: var(--sp-3); border-top: 1px solid var(--border);"
  >
    <span class="row gap-2 muted" style="font-size: var(--fs-12);">
      <span class="avatar">{post.author.display_name?.[0]?.toUpperCase() ?? "J"}</span>
      {post.author.display_name}
    </span>
    <span class="muted" style="font-size: var(--fs-12);">{minutes} min read</span>
  </div>
</a>
