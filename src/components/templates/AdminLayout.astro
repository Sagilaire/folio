---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---
<section class="container" style="padding: var(--sp-6) 0 var(--sp-9);">
  <div class="stack gap-2" style="margin-bottom: var(--sp-6); padding-bottom: var(--sp-4); border-bottom: 1px solid var(--border);">
    <div class="row gap-2 muted" style="font-family: var(--mono); font-size: var(--fs-12);">
      <a href="/" style="color: inherit;">FOLIO</a>
      <span>›</span>
      <a href="/admin" style="color: inherit;">Editor</a>
    </div>
    <div class="stack gap-1">
      <h1 class="display display-lg serif" style="margin:0;">{title}</h1>
      {subtitle && <p class="muted serif" style="font-size: var(--fs-18); margin:0; max-width: 60ch;">{subtitle}</p>}
    </div>
  </div>
  <slot />
</section>
