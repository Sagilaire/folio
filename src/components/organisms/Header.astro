---
import { BRAND } from "@/lib/site";

const user = Astro.locals.session?.user;
const pathname = Astro.url.pathname;
const isAdmin = pathname.startsWith("/admin");
---
<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand">
      <span class="dot"></span>
      {BRAND.name}
    </a>
    <nav class="site-header__nav">
      <a href="/posts">Read</a>
      {user ? (
        <>
          <a href="/admin" class:list={[isAdmin && "muted"]}>Editor</a>
          <span style="display:inline-flex; align-items:center; gap:8px; padding-left:12px; border-left: 1px solid var(--border);">
            <span class="avatar">{user.email?.[0]?.toUpperCase() ?? "J"}</span>
            <span style="font-size:var(--fs-12); color:var(--muted);">{user.email}</span>
            <form action="/logout" method="POST" style="display:inline; margin:0;">
              <button type="submit" class="btn btn--sm btn--ghost">Sign out</button>
            </form>
          </span>
        </>
      ) : (
        <a href="/login" class="btn btn--sm btn--primary">Sign in</a>
      )}
    </nav>
  </div>
</header>
