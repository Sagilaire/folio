{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["@cloudflare/workers-types", "vitest/globals"]
  },
  "include": [".astro/types.d.ts", "src/env.d.ts", "src/**/*.ts", "src/**/*.tsx", "src/**/*.astro", "tests/**/*.ts"],
  "exclude": ["dist", "node_modules", ".astro", "worker"]
}
