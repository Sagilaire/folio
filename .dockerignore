# .dockerignore — exclusion list for Docker build context.
# Mirrors .gitignore but also drops everything we don't need on the build host.

# ── Version control ─────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Node — reinstall inside the container ──────────────────────────────────
node_modules

# ── Build output — regenerated inside the container ─────────────────────────
dist
.astro
.wrangler
.dev.vars
.dev.vars.example

# ── Test artifacts ──────────────────────────────────────────────────────────
coverage
playwright-report
test-results
playwright/.cache
tests

# ── Logs ───────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Editor / OS noise ──────────────────────────────────────────────────────
.vscode
.idea
.DS_Store
Thumbs.db

# ── CI ──────────────────────────────────────────────────────────────────────
.github

# ── Env files ──────────────────────────────────────────────────────────────
# We INTENTIONALLY keep `.env` and `.env.example` in the build context so
# Astro inlines `PUBLIC_*` vars into the client bundle at build time.
# Drop the COMMITTED `.env*` rule below if you ever switch to build-args.
.env.local
.env.*.local
