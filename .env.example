# FOLIO — environment variables
#
# Copy to `.env` for local development. Set the server-side keys without the
# PUBLIC_ prefix in Cloudflare Pages → Environment Variables when you deploy.
# Use `wrangler secret put` for the SERVICE_ROLE key.
# ============================================================================

# Public site URL — used for og:url / canonical links.
PUBLIC_SITE_URL=http://localhost:4321

# ── Supabase SERVER (Astro middleware + API routes) ─────────────────────────
# Get these from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-ANON-KEY

# ── Supabase BROWSER bundle (inlined into the React island) ─────────────────
# Same values as above — the anon key is designed to be public.
# Required by src/components/organisms/AuthForm.tsx.
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-ANON-KEY

# ── Worker ONLY — wrangler secret (NEVER in the browser bundle) ─────────────
# Service role bypasses RLS. Set via:
#   cd worker && wrangler secret put SUPABASE_SERVICE_ROLE_KEY
# Leave blank locally.
SUPABASE_SERVICE_ROLE_KEY=
